# Copia a .env
VZ_SEARCH_GEMINI_API_KEY=
VZ_SEARCH_INGEST_MODE=ai
VZ_SEARCH_STORAGE=sqlite
VZ_SEARCH_INGEST_INCREMENTAL=true
